rules_version = '2';

// ============================================================
// FIRESTORE SECURITY RULES
// ------------------------------------------------------------
// Deploy with: firebase deploy --only firestore:rules
//
// Key protections:
//  - A user can only read/write their OWN document (matched by uid).
//  - A user can NEVER set `paid` themselves — that field is only
//    ever changed by the verifyPaystackPayment Cloud Function, which
//    runs with admin privileges and bypasses these rules entirely.
//    We enforce this by rejecting any client-side write that touches
//    the `paid` or `purchaseDate` fields.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {

      // Anyone signed in can read their own profile (for dashboard unlock checks).
      allow read: if request.auth != null && request.auth.uid == userId;

      // Allow creating your own doc on sign-up, but never with paid:true.
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.paid == false;

      // Allow updates ONLY to completedDays — never to paid or purchaseDate
      // or transactionRef. Those are exclusively set server-side.
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.paid == resource.data.paid
                    && request.resource.data.purchaseDate == resource.data.purchaseDate
                    && request.resource.data.transactionRef == resource.data.transactionRef;

      allow delete: if false;
    }
  }
}
